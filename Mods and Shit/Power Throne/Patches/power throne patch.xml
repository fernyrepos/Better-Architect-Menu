<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>/Defs/ThingDef[defName="PowerThrone_Throne" or defName="PowerThrone_SideCasket"]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Meditation</designationCategory>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>/Defs/ThingDef[(defName="PowerThrone_Throne" or defName="PowerThrone_SideCasket") and not(designationCategory)]</xpath>
    <value>
      <designationCategory>Ferny_Meditation</designationCategory>
    </value>
  </Operation>
</Patch>
