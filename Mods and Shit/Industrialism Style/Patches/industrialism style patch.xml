<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>/Defs/ThingDef[defName="TW_Industrialism_EmergencyLight"]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Lighting</designationCategory>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>/Defs/ThingDef[defName="TW_Industrialism_EmergencyLight" and not(designationCategory)]</xpath>
    <value>
      <designationCategory>Ferny_Lighting</designationCategory>
    </value>
  </Operation>
</Patch>
