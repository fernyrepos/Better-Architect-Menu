<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>/Defs/ThingDef[(defName="MF_CorporateExecutiveOfficeDesk" or defName="MF_CorporateSimpleOfficeDesk")]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Production</designationCategory>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>/Defs/ThingDef[(defName="MF_CorporateExecutiveOfficeDesk" or defName="MF_CorporateSimpleOfficeDesk") and not(designationCategory)]</xpath>
    <value>
      <designationCategory>Ferny_Production</designationCategory>
    </value>
  </Operation>
</Patch>
