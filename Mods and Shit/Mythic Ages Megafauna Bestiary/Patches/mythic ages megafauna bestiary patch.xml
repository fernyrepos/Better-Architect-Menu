<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="PatchOperationAddModExtension">
    <success>Always</success>
    <xpath>Defs/DesignationCategoryDef[defName="MA_MythicProduction_Tribal"]</xpath>
    <value>
      <li Class="BetterArchitect.NestedCategoryExtension">
        <parentCategory>Production</parentCategory>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/ThingDef[defName="MA_FlatButcherBlock"]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Kitchen</designationCategory>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/ThingDef[defName="MA_MythicCraftingSpot"]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Production</designationCategory>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/ThingDef[defName="MA_FlatCraftingBench"]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Production</designationCategory>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/ThingDef[defName="MA_FlatCookingTable"]/designationCategory</xpath>
    <value>
      <designationCategory>Ferny_Kitchen</designationCategory>
    </value>
  </Operation>

</Patch>
